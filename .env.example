# Скопируйте этот файл в .env и заполните значения

# Eagle Doc OCR API Key (для сканирования чеков — обязательно)
EAGLE_DOC_API_KEY=

# Anthropic API Key (для меню-AI и парсинга текстового заказа)
ANTHROPIC_API_KEY=sk-ant-api03-...

# VAPID ключи для Push-уведомлений (необязательно)
# Сгенерировать: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@splitaway.netlify.app
